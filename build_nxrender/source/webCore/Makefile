	cd /home/swana/Documents/zeprabrowser/build_nxrender && $(MAKE) $(MAKESILENT) -f source/webCore/CMakeFiles/webcore.dir/build.make source/webCore/CMakeFiles/webcore.dir/src/webgl_context.cpp.i
.PHONY : src/webgl_context.cpp.i

src/webgl_context.s: src/webgl_context.cpp.s
.PHONY : src/webgl_context.s

# target to generate assembly for a file
src/webgl_context.cpp.s:
	cd /home/swana/Documents/zeprabrowser/build_nxrender && $(MAKE) $(MAKESILENT) -f source/webCore/CMakeFiles/webcore.dir/build.make source/webCore/CMakeFiles/webcore.dir/src/webgl_context.cpp.s
.PHONY : src/webgl_context.cpp.s

